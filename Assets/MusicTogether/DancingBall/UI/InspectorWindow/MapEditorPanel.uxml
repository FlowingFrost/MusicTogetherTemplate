<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/MusicTogether/DancingBall/UI/DancingBallEditor_Common.uss?fileID=7433441132597879392&amp;guid=1dcdcf878d12b194da051df375cde7a8&amp;type=3#DancingBallEditor_Common" />
    <ui:VisualElement name="map-root" class="db-panel">
        <ui:VisualElement name="map-common-container" class="db-section">
            <ui:Label text="Map 通用选项" name="map-common-header" class="db-title" />
            <ui:Button name="map-rebuild-roads" text="重建Road列表，清理重复和无效Road，添加缺失Road" class="db-button" />
            <ui:Button name="map-refresh-all-roads" text="刷新所有Road，重建Block列表" class="db-button" />
        </ui:VisualElement>
        <ui:VisualElement name="map-derived-container" class="db-section db-section-spaced" style="display: none;">
            <ui:Label text="Map 继承类选项" name="map-derived-header" class="db-title" />
            <ui:Label text="（当前无继承类专属操作）" name="map-derived-empty" class="db-muted" />
        </ui:VisualElement>
        <ui:VisualElement name="map-missbinding-container" class="db-section" style="display: none;">
            <ui:Label tabindex="-1" text="Map丢失绑定" parse-escape-sequences="true" display-tooltip-when-elided="true" class="db-title" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
