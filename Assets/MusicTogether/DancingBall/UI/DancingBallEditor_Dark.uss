:root {
    /* 
     * DancingBall Editor UI - Dark Theme Variables
     * Used github-dark inspired color palette
     */
    --db-accent: rgb(88, 166, 255);
    --db-text: rgb(201, 209, 217);
    --db-muted: rgb(139, 148, 158);
    --db-surface: rgb(33, 38, 45);
    --db-surface-alt: rgb(13, 17, 23);
    --db-border: rgb(48, 54, 61);
    --db-button-bg: rgb(33, 38, 45);
    --db-button-bg-hover: rgb(48, 54, 61);
    --db-input-bg: rgb(13, 17, 23);
}